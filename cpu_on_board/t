i_cache_refill:
     andi x9, x9, -16 # 16 bytes align
     lui x4, 0x20001 # base Cache address
     ld x3, 0(x9)    # get data
     sd x3, 0(x4)    # refill line low 64
     ld x3, 8(x9)    # get data
     sd x3, 8(x4)    # refill line high 64  

    #lui x3, 0x2     
    #addi x3, x3, 0x4  # set print           
    #addi x6, x0, 0x25
    #sd x6, 0(x3)    #  print %

    #mv a0, x9
    #call print_reg

    #li a0, "ICAre:"
    #call print7
    #mv a0, x9
    #call print_reg

     addi x8, x0, 0  # success x8=0
     j return

mmu_i:
     #li a0, "\n[i"
     #call print7
     li a0, "i"
     sb a0, 0(x7)
     j mmu
mmu_d:
     #li a0, "\n[d"
