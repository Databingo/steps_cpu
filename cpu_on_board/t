print_reg: # a0
    addi sp, sp, -40
    sd ra, 0(sp)
    sd x6, 8(sp)
    sd x3, 16(sp)
    sd x4, 24(sp)
    sd x5, 32(sp)
    mv x6, a0
    li a0, "0"
    call putchar
    li a0, "x"
    call putchar
    li x3, 60 
p_loop:
    srl x4, x6, x3      # get high nibble
    andi x4, x4, 0xF
    slti x5, x4, 10     # if < 10 number
    beq x5, x0, letter
    addi x4, x4, 48     # 0 is "0" ascii 48
    j print_h
letter:
    addi x4, x4, 55     # 10 is "A" ascii 65 ..
print_h:
    call wait_uart
    sb x4, 0(x7)       # print
    addi x3, x3, -4
    bge x3, x0, p_loop 
    ld ra, 0(sp)
    ld x6, 8(sp)
    ld x3, 16(sp)
    ld x4, 24(sp)
    ld x5, 32(sp)
    addi sp, sp, 40
    ret


