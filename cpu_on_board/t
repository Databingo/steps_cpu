    #beq x8, x3, mmu_d    # d-tlb-refill Load
     beq x8, x3, mmu      # d-tlb-refill Load

     li x3, 15 
    #beq x8, x3, mmu_d    # d-tlb-refill Store
     beq x8, x3, mmu      # d-tlb-refill Store

