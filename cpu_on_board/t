	//assign tlb_d_match[15] = tlb_d_vld[15] && (tlb_d_vpn[15] == ls_va[38:12]);

	always @(*) begin
	    tlb_d_hit = |tlb_d_match && !tlb_flush;
	    data_ppn = ({44{tlb_d_match[0]}} & tlb_d_ppn[0]) |
