This is a great idea. To mimic a real OS (like Linux), this program will:

Run in S-Mode: Verify OpenSBI successfully dropped privilege.

Use SBI Calls: Ask OpenSBI to print characters (mimics early Linux printk).

Setup Sv39 MMU: Create a "Mega-Page" (1GB) identity map.

Enable Virtual Memory: Write to satp and execute sfence.vma.

Handle a Trap: Set stvec and trigger an exception to prove delegation works.

1. The Assembly Code (payload.S)

I have designed this to be very simple. It maps the first 1GB of memory identity-mapped (Virtual Address = Physical Address) so the CPU doesn't crash when you turn the MMU on.

code
Assembly
download
content_copy
expand_less
# payload.S
.section .text
.globl _start

_start:
    # 1. Print 'S' using SBI call to prove we are in S-mode
    # SBI Extension: Console Putchar (0x01)
    li a7, 0x01
    li a0, 'S'
    ecall

    li a0, ' '
    ecall

    # 2. Build a minimal Sv39 Page Table
    # We will put the Root Table at 0x80400000
    # We identity map the first 1GB (covers your RAM and Hardware)
    # VPN[2] for 0x80000000 is index 2.
    
    li t0, 0x80400000      # Root Table Base
    
    # Construct PTE (Page Table Entry)
    # PPN = 0 (to cover address 0x00000000 - 0x3FFFFFFF)
    # Bits: D A G U X W R V
    #        1 1 0 0 1 1 1 1  => 0xCF
    li t1, 0xCF            # Valid, Read, Write, Execute, Accessed, Dirty
    sd t1, 0(t0)           # Map 0GB - 1GB (Index 0)

    # Map 2nd GB (covers 0x80000000)
    # PPN for 0x80000000 is 0x80000
    li t1, 0x80000         # PPN
    slli t1, t1, 10        # Shift to PPN position
    ori t1, t1, 0xCF       # Add flags
    sd t1, 16(t0)          # Index 2 (Address 0x80000000)

    # 3. Enable MMU (Set satp)
    # Mode = 8 (Sv39), ASID = 0, PPN = 0x80400000 >> 12 (0x80400)
    li t2, (8 << 60) | (0x80400)
    
    # Standard Linux sequence:
    sfence.vma             # Flush TLB
    csrw satp, t2          # TURN ON MMU
    sfence.vma             # Flush again
    
    # 4. If we are still alive here, Virtual Memory is WORKING!
    li a7, 0x01
    li a0, 'V'
    ecall
    li a0, 'M'
    ecall
    li a0, ' '
    ecall
    li a0, 'O'
    ecall
    li a0, 'N'
    ecall

    # 5. Test Delegation (Handing traps to S-mode)
    la t0, s_trap_handler
    csrw stvec, t0         # Set Supervisor Trap Vector
    
    ebreak                 # Trigger a trap!

loop:
    j loop

.align 4
s_trap_handler:
    # If we get here, it means the 'ebreak' trapped to S-mode, not M-mode!
    li a7, 0x01
    li a0, 'T'
    ecall
    li a0, 'R'
    ecall
    li a0, 'A'
    ecall
    li a0, 'P'
    ecall
    
    # Done! Hang forever
