#!/bin/busybox sh
# 1. Mount /dev so Linux can create /dev/console and /dev/hvc0
/bin/busybox mount -t devtmpfs devtmpfs /dev

exec 0</dev/console
exec 1>/dev/console
exec 2>/dev/console


# 2. Print a big banner to prove output works over hvc0
echo "========================================="
echo " SUCCESS! CUSTOM INIT SCRIPT IS RUNNING! "
echo " console=hvc0 output is working perfectly"
echo "========================================="

# 3. Test input (This will probably hang because of no mtip)
echo "Please type something and press Enter:"
read my_input
echo "You typed: $my_input"

# 4. Infinite loop to keep the kernel alive. 
# WARNING: Do NOT use 'sleep 1', because sleep requires mtip!
# We use a math loop to slow down the text instead.
echo "Entering infinite loop..."
while true; do
    echo "Linux is alive!"
    
    # Busy-wait loop (replaces 'sleep' since timers are broken)
    i=0
    while [ $i -lt 50000 ]; do
        i=$((i+1))
    done
done
