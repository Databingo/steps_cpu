#!/bin/busybox sh

# 1. Mount filesystems
/bin/busybox mount -t devtmpfs devtmpfs /dev
/bin/busybox mount -t proc proc /proc

# 2. Try to redirect to console, but don't die if it fails
exec 0</dev/console >/dev/console 2>/dev/console

# 3. Write to /dev/kmsg (This bypasses the HVC buffer and shows up in dmesg immediately!)
echo "INIT: Script started" > /dev/kmsg
echo "INIT: Busybox version: $(/bin/busybox --help | head -n 1)" > /dev/kmsg

echo "========================================="
echo "   IMA BUSYBOX IS ALIVE!                 "
echo "========================================="

# 4. Infinite loop using ':' (the built-in)
while :; do
    echo "LOOP: Heartbeat at $(/bin/busybox date)" > /dev/kmsg
    echo "Console Heartbeat..."
    
    # Simple delay loop
    i=0
    while [ $i -lt 10000 ]; do
        i=$((i+1))
    done
done
